{%- if compilation_task.log_file %} <a href="{{ compilation_task.log_file }}" class="log-link" target="_blank" rel="noopener noreferrer">[log]</a>{%- endif %}
{%- else %}-{%- endif %}
</div>
<div class="chart-cell chart-status">
{%- if sanity_task %}
{%- if sanity_task.status == 'passed' %}
<span class="success">✅ PASSED</span>{%- if sanity_task.time %} <span class="chart-timing">({{ sanity_task.time }})</span>{%- endif %}
{%- elif sanity_task.status == 'running' %}
<span style="color: #3498db;"><span class="spinner"></span>RUNNING</span>{%- if sanity_task.time %} <span class="chart-timing">(elapsed <span class="elapsed-seconds" data-start-epoch="{{ sanity_task.start_epoch or '' }}">{{ sanity_task.time.replace('elapsed ', '').replace('s', '') }}</span>s)</span>{%- endif %}
{%- elif sanity_task.status == 'killed' %}
<span style="color: #ff9800; font-weight: bold;">⚠️ KILLED</span>{%- if sanity_task.time %} <span class="chart-timing">({{ sanity_task.time }})</span>{%- endif %}
{%- elif sanity_task.status == 'queued' %}
<span style="color: #95a5a6;">⏳ QUEUED</span>{%- if sanity_task.time %} <span class="chart-timing">(prev: {{ sanity_task.time }})</span>{%- endif %}
{%- elif sanity_task.status == 'skipped' %}
<span style="color: #95a5a6;">SKIPPED</span>{%- if sanity_task.prev_status %} <span class="chart-timing">(prev: <span class="success">PASSED</span>{%- if sanity_task.time %} {{ sanity_task.time }}{%- endif %})</span>{%- endif %}
{%- else %}
<span class="failure">❌ FAILED</span> <span class="chart-timing">({{ sanity_task.time if sanity_task.time else 'n/a' }})</span>
{%- endif %}
{%- if sanity_task.log_file %} <a href="{{ sanity_task.log_file }}" class="log-link" target="_blank" rel="noopener noreferrer">[log]</a>{%- endif %}
{%- else %}-{%- endif %}
</div>
{# image size for compressed image #}
<div class="chart-cell chart-size">
{%- if target_data.image_size %}{{ target_data.image_size }}{%- else %}-{%- endif %}
</div>
{%- elif target_name == 'dev-upload' %}
<div class="chart-cell chart-status chart-cell-span-3" style="text-align: center;">
{%- if no_upload and not (build_task and build_task.status == 'skipped' and build_task.prev_status) %}<span style="color: #95a5a6;">Disabled (--no-upload)</span>
{%- elif build_task %}
{%- if build_task.status == 'passed' %}
<span class="success">✅ UPLOADED</span>{%- if build_task.time %} <span class="chart-timing">({{ build_task.time }})</span>{%- endif %}
{%- elif build_task.status == 'running' %}
<span style="color: #3498db;"><span class="spinner"></span>UPLOADING</span>{%- if build_task.time %} <span class="chart-timing">(elapsed <span class="elapsed-seconds" data-start-epoch="{{ build_task.start_epoch or '' }}">{{ build_task.time.replace('elapsed ', '').replace('s', '') }}</span>s)</span>{%- endif %}
{%- elif build_task.status == 'killed' %}
<span style="color: #ff9800; font-weight: bold;">⚠️ KILLED</span>{%- if build_task.time %} <span class="chart-timing">({{ build_task.time }})</span>{%- endif %}
{%- elif build_task.status == 'queued' %}
<span style="color: #95a5a6;">⏳ QUEUED</span>{%- if build_task.time %} <span class="chart-timing">(prev: {{ build_task.time }})</span>{%- endif %}
{%- elif build_task.status == 'skipped' %}
<span style="color: #95a5a6;">SKIPPED</span>{%- if build_task.prev_status %} <span class="chart-timing">(prev: <span class="success">UPLOADED</span>{%- if build_task.time %} {{ build_task.time }}{%- endif %})</span>{%- endif %}
{%- else %}
<span class="failure">❌ FAILED</span> <span class="chart-timing">({{ build_task.time if build_task.time else 'n/a' }})</span>
{%- endif %}
{%- if build_task.log_file %} <a href="{{ build_task.log_file }}" class="log-link" target="_blank" rel="noopener noreferrer">[log]</a>{%- endif %}
{%- else %}-{%- endif %}
</div>
<div class="chart-cell chart-size">
{%- set compress_data = targets.get('dev-compress', {}) %}
{%- if compress_data and compress_data.image_size %}{{ compress_data.image_size }}{%- elif targets.get('dev', {}).image_size %}{{ targets['dev'].image_size }}{%- else %}-{%- endif %}
</div>
{%- else %}
{%- if target_name == 'runtime' %}
{# Runtime has no compilation -- build spans both columns #}
<div class="chart-cell chart-status chart-cell-span-2">
{%- else %}
<div class="chart-cell chart-status">
{%- endif %}
{%- if no_build and build_task and build_task.status == 'skipped' %}<span style="color: #95a5a6;">Disabled (--no-build)</span>
{%- elif build_task %}
{%- if build_task.status == 'passed' %}
